#========================
# 1. Import des données
#========================

info <- read.delim(
  "C:/Users/2026mr001/Desktop/Stage/Identification cif/cif-like/Check conta/Genomes_references/info.txt",
  check.names = FALSE
)

names(info) <- trimws(names(info))

info$Name_original <- info$Name

info$Sequence <- sub("/.*", "", info$Sequence)
info$Clade <- factor(info$Clade)

# Conversion en numérique si nécessaire
info <- info %>%
  mutate(
    GC = as.numeric(GC),
    coding_density = as.numeric(coding_density),
    CDSs = as.numeric(CDSs),
    hypotheticals = as.numeric(hypotheticals)
  )

# Conversion éventuelle en proportions [0,1]
if (max(info$GC, na.rm = TRUE) > 1) {
  info$GC <- info$GC / 100
}

if (max(info$coding_density, na.rm = TRUE) > 1) {
  info$coding_density <- info$coding_density / 100
}

# Proportions à l'échelle de la souche
info <- info %>%
  mutate(
    prop_hypothetical = hypotheticals / CDSs,
    prop_annotated = (CDSs - hypotheticals) / CDSs
  )

# Données pour les figures : toutes les modalités
info_fig <- info %>%
  mutate(
    Clade = factor(Clade, levels = c("Bacterie", "Eucaryote", "Candidat"))
  )

# Données pour les tests : uniquement Eucaryote et Bacterie
info_stats <- info %>%
  filter(Clade %in% c("Eucaryote", "Bacterie")) %>%
  mutate(
    Clade = factor(Clade, levels = c("Bacterie", "Eucaryote"))
  ) %>%
  droplevels()

# Vérifications rapides
