library(ggplot2)
library(dplyr)
library(tidyr)
library(ggalluvial)
library(patchwork)

df <- tibble(
  etape = 1:5,
  Liste = c(45, 45, 45, 45, 7),
  Genome_tblastx = c(8, 2, 2, 2, 2),
  Genome_tblastn = c(8, 2, 2, 2, 2),
  Blast_tblastx  = c(36, 18, 5, 3, 1),
  Blast_tblastn  = c(34, 16, 13, 9, 3),
  Blast_blastp   = c(94, 35, 35, 33, 12)
)

dat <- df %>%
  pivot_longer(
    cols = -etape,
    names_to = "variable",
    values_to = "n"
  ) %>%
  mutate(
    source = case_when(
      variable == "Liste" ~ "Liste",
      grepl("^Genome_", variable) ~ "Genome",
      grepl("^Blast_", variable) ~ "Blast"
    ),
    methode = case_when(
      variable == "Liste" ~ "Liste",
      TRUE ~ sub("^[^_]+_", "", variable)
    )
  )

cols <- c(
  "Liste" = "#ff0000",
  "tblastx" = "#9f05f5",
  "tblastn" = "#ffd966",
  "blastp" = "#00b0f0"
)

theme_workflow <- theme_minimal(base_size = 12) +
  theme(
    panel.grid = element_blank(),
    axis.title = element_blank(),
    axis.text.y = element_blank(),
    axis.ticks = element_blank(),
    legend.position = "bottom"
  )

plot_source <- function(data, nom_source) {
  
  data_source <- data %>%
    filter(source == nom_source, etape <= 3) %>%
    mutate(
      etape_lab = factor(
        etape,
        levels = 1:3,
        labels = c("Étape 1", "Étape 2", "Étape 3")
      ),
      flux = variable,
      stratum = variable
    )
  
  ggplot(
    data_source,
    aes(
      x = etape_lab,
      stratum = stratum,
      alluvium = flux,
      y = n,
      fill = methode
    )
  ) +
    geom_flow(
      alpha = 0.45,
      color = "grey40",
      width = 0.25
    ) +
    geom_stratum(
      width = 0.25,
      color = "black",
      linewidth = 0.3
    ) +
    geom_text(
      stat = "stratum",
      aes(label = after_stat(count)),
      size = 3
    ) +
    scale_fill_manual(values = cols) +
    labs(title = nom_source, fill = "Méthode") +
    theme_workflow
}

plot_common <- dat %>%
  filter(etape >= 4) %>%
  mutate(
    etape_lab = factor(
      etape,
      levels = 4:5,
      labels = c("Étape 4", "Étape 5")
    ),
    flux = variable,
    stratum = source
  ) %>%
  ggplot(
    aes(
      x = etape_lab,
      stratum = stratum,
      alluvium = flux,
      y = n,
      fill = methode
    )
  ) +
  geom_flow(
    alpha = 0.45,
    color = "grey40",
    width = 0.25
  ) +
  geom_stratum(
    width = 0.25,
    color = "black",
    linewidth = 0.3
  ) +
  geom_text(
    stat = "stratum",
    aes(label = after_stat(count)),
    size = 3
  ) +
  scale_fill_manual(values = cols) +
  labs(title = "Workflow commun", fill = "Méthode") +
  theme_workflow

p_liste  <- plot_source(dat, "Liste")
p_genome <- plot_source(dat, "Genome")
p_blast  <- plot_source(dat, "Blast")

figure_finale <- 
  (p_liste | p_genome | p_blast) /
  plot_common +
  plot_layout(heights = c(1, 1.1)) +
  plot_annotation(title = "Workflow de filtrage par source puis workflow commun")

figure_finale
