library(gt)
library(dplyr)
library(stringr)

tab <- read.delim(
  "C:/Users/Mael RICHON/Desktop/Retours_Julien_correction_25-05/tab1.txt",
  sep = "\t",
  header = TRUE,
  stringsAsFactors = FALSE,
  check.names = FALSE,
  fileEncoding = "UTF-8-BOM"
)

# On force des noms propres aux colonnes
names(tab) <- c("Lignée donneuse", "Lignée receveuse", "Description", "Référence")

# On enlève les caractères invisibles qui foutent le bazar
tab <- tab %>%
  mutate(across(
    everything(),
    ~ str_replace_all(.x, "[\u200B\u200C\u200D\uFEFF]", "")
  ))

# Noms à mettre en italique
noms_italique <- c(
  "Ixodes scapularis",
  "Planococcus citri",
  "Borrelia burgdorferi",
  "Tremblaya princeps"
)

# Remplacement automatique par du markdown
for (nom in noms_italique) {
  tab <- tab %>%
    mutate(across(
      everything(),
      ~ str_replace_all(.x, fixed(nom), paste0("*", nom, "*"))
    ))
}

# Tableau final
gt(tab) %>%
  fmt_markdown(columns = everything()) %>%
  opt_row_striping() %>%
  cols_align(
    align = "left",
    columns = everything()
  ) %>%
  tab_style(
    style = cell_text(
      weight = "bold",
      v_align = "middle",
      color = "black"
    ),
    locations = cells_column_labels(columns = everything())
  ) %>%
  tab_style(
    style = cell_text(
      color = "black"
    ),
    locations = cells_body(columns = everything())
  ) %>%
  tab_options(
    table.font.color = "black",
    row.striping.background_color = "white",
    data_row.padding = px(6),
    column_labels.padding = px(8)
  )
