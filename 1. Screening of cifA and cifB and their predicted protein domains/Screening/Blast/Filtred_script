library(dplyr)

d = Total_CifA #or Total_CifB
d$E_value <- as.numeric(gsub(",", ".", d$E_value))

# First, we keep only one row per accession number and per method
d_slice <- d %>%
  group_by(Accession, Methode) %>%
  arrange(E_value, .by_group = TRUE) %>%
  slice(1) %>%
  ungroup()

# Then, for each Taxid, we choose to keep only the two sequences with the lowest E_value
f <- d_slice %>%
  group_by(Taxid, Methode) %>%
  arrange(E_value, .by_group = TRUE) %>%
  slice_head(n = 2) %>%
  ungroup()

# Finally, we keep only one line per accession, regardless of the method
f <- f %>%
  group_by(Accession) %>%
  arrange(E_value, .by_group = TRUE) %>%
  slice_head(n = 1) %>%
  ungroup()
